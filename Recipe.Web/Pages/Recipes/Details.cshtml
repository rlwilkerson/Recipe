@page "/recipes/{publicId}/{slug}"
@model Recipe.Web.Pages.Recipes.DetailsModel
@{
    ViewData["Title"] = Model.Result?.Title ?? "Recipe Details";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Cookbooks/Index">My Cookbooks</a></li>
        @if (Model.Result?.Cookbooks?.Count > 0)
        {
            var firstCookbook = Model.Result.Cookbooks[0];
            <li class="breadcrumb-item">
                <a href="/cookbooks/@firstCookbook.PublicId/@firstCookbook.Slug">@firstCookbook.Name</a>
            </li>
        }
        <li class="breadcrumb-item active" aria-current="page">@Model.Result?.Title</li>
    </ol>
</nav>

<partial name="_RecipeViewContent" model="Model.Result" />

<!-- Delete Recipe Modal -->
<div class="modal fade" id="deleteRecipeModal" tabindex="-1" aria-labelledby="deleteRecipeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteRecipeModalLabel">Delete Recipe</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong>@Model.Result?.Title</strong>?</p>
                <p class="text-danger"><strong>This action cannot be undone.</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form hx-post="?handler=Delete" hx-swap="none">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete Recipe</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Share Modal -->
<div class="modal fade" id="shareModal" tabindex="-1" aria-labelledby="shareModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="shareModalLabel">Share Recipe</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body"
                 id="share-modal-body"
                 hx-get="?handler=ShareSection"
                 hx-trigger="shown.bs.modal from:#shareModal">
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                    <span class="ms-2">Loading...</span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyLinkToClipboard() {
            navigator.clipboard.writeText(window.location.href).then(function() {
                alert('Link copied to clipboard!');
            }, function() {
                alert('Failed to copy link');
            });
        }
    </script>
}

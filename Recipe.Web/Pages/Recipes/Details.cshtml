@page "/recipes/{publicId}/{slug}"
@model Recipe.Web.Pages.Recipes.DetailsModel
@{
    ViewData["Title"] = Model.Result?.Title ?? "Recipe Details";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Result?.Title</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-8">
        <h1>@Model.Result?.Title</h1>
        
        @if (Model.Result?.OriginalRecipePublicId != null)
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> This recipe was cloned from another recipe
            </div>
        }

        @if (Model.Result?.PrepTime != null || Model.Result?.CookTime != null || Model.Result?.Servings != null)
        {
            <div class="d-flex gap-4 mb-3 text-muted">
                @if (Model.Result.PrepTime.HasValue)
                {
                    <span><strong>Prep:</strong> @Model.Result.PrepTime min</span>
                }
                @if (Model.Result.CookTime.HasValue)
                {
                    <span><strong>Cook:</strong> @Model.Result.CookTime min</span>
                }
                @if (Model.Result.Servings.HasValue)
                {
                    <span><strong>Serves:</strong> @Model.Result.Servings</span>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Result?.Description))
        {
            <p class="lead">@Model.Result.Description</p>
        }

        <div class="mb-4">
            <h3>Ingredients</h3>
            @if (!string.IsNullOrWhiteSpace(Model.Result?.Ingredients))
            {
                <ul class="list-unstyled">
                    @foreach (var ingredient in Model.Result.Ingredients.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <li class="mb-1">@ingredient.Trim()</li>
                    }
                </ul>
            }
        </div>

        <div class="mb-4">
            <h3>Instructions</h3>
            @if (!string.IsNullOrWhiteSpace(Model.Result?.Instructions))
            {
                <ol>
                    @foreach (var instruction in Model.Result.Instructions.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <li class="mb-2">@instruction.Trim()</li>
                    }
                </ol>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Actions</h5>
                <div class="d-grid gap-2">
                    <form method="post" asp-page-handler="Clone">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-files"></i> Clone Recipe
                        </button>
                    </form>
                    <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#shareModal">
                        <i class="bi bi-share"></i> Share
                    </button>
                    <button class="btn btn-outline-secondary" onclick="copyLinkToClipboard()">
                        <i class="bi bi-link-45deg"></i> Copy Link
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Share Modal (stub) -->
<div class="modal fade" id="shareModal" tabindex="-1" aria-labelledby="shareModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="shareModalLabel">Share Recipe</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Share functionality coming soon!</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyLinkToClipboard() {
            navigator.clipboard.writeText(window.location.href).then(function() {
                alert('Link copied to clipboard!');
            }, function() {
                alert('Failed to copy link');
            });
        }
    </script>
}

@model Recipe.Web.Features.Recipes.GetRecipe.GetRecipeResponse

<div id="recipe-content">
    <div class="row">
        <div class="col-lg-8">
            <h1>@Model?.Title</h1>
            
            @if (Model?.OriginalRecipePublicId != null)
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> This recipe was cloned from another recipe
                </div>
            }

            @if (Model?.PrepTime != null || Model?.CookTime != null || Model?.Servings != null)
            {
                <div class="d-flex gap-4 mb-3 text-muted">
                    @if (Model.PrepTime.HasValue)
                    {
                        <span><strong>Prep:</strong> @Model.PrepTime min</span>
                    }
                    @if (Model.CookTime.HasValue)
                    {
                        <span><strong>Cook:</strong> @Model.CookTime min</span>
                    }
                    @if (Model.Servings.HasValue)
                    {
                        <span><strong>Serves:</strong> @Model.Servings</span>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model?.Description))
            {
                <p class="lead">@Model.Description</p>
            }

            <div class="mb-4">
                <h3>Ingredients</h3>
                @if (!string.IsNullOrWhiteSpace(Model?.Ingredients))
                {
                    <ul class="list-unstyled">
                        @foreach (var ingredient in Model.Ingredients.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <li class="mb-1">@ingredient.Trim()</li>
                        }
                    </ul>
                }
            </div>

            <div class="mb-4">
                <h3>Instructions</h3>
                @if (!string.IsNullOrWhiteSpace(Model?.Instructions))
                {
                    <ol>
                        @foreach (var instruction in Model.Instructions.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <li class="mb-2">@instruction.Trim()</li>
                        }
                    </ol>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Actions</h5>
                    <div class="d-grid gap-2">
                        @if (Model?.IsOwner == true)
                        {
                            <button class="btn btn-warning w-100"
                                    hx-get="?handler=EditForm"
                                    hx-target="#recipe-content"
                                    hx-swap="outerHTML">
                                <i class="bi bi-pencil"></i> Edit Recipe
                            </button>
                            <button type="button" class="btn btn-danger w-100"
                                    data-bs-toggle="modal" data-bs-target="#deleteRecipeModal">
                                <i class="bi bi-trash"></i> Delete Recipe
                            </button>
                        }
                        <button class="btn btn-primary w-100"
                                hx-get="?handler=CloneForm"
                                hx-target="#recipe-content"
                                hx-swap="outerHTML">
                            <i class="bi bi-files"></i> Clone Recipe
                        </button>
                        <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#shareModal">
                            <i class="bi bi-share"></i> Share
                        </button>
                        <button class="btn btn-outline-secondary" onclick="copyLinkToClipboard()">
                            <i class="bi bi-link-45deg"></i> Copy Link
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

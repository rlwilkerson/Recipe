@page
@model Recipe.Web.Pages.Cookbooks.IndexModel
@{
    ViewData["Title"] = "My Cookbooks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My Cookbooks</h1>
    <button hx-get="/cookbooks?handler=CreateCookbookModal"
            hx-target="#modal-container"
            hx-swap="innerHTML"
            class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create Cookbook
    </button>
</div>

<div id="cookbook-list">
    <partial name="_CookbookList" model="Model.Result?.Cookbooks" />
</div>

<div id="modal-container"></div>

@section Scripts {
    <script>
        // Fallback for non-HTMX browsers
        if (typeof htmx === 'undefined') {
            document.querySelector('[hx-get]').addEventListener('click', function(e) {
                window.location.href = '/cookbooks?handler=CreateCookbookModal';
            });
        }
    </script>
}

@page "/cookbooks/{publicId}/{slug}"
@model Recipe.Web.Pages.Cookbooks.DetailsModel
@{
    ViewData["Title"] = Model.Result?.Name ?? "Cookbook Details";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Cookbooks/Index">My Cookbooks</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Result?.Name</li>
    </ol>
</nav>

<partial name="_CookbookHeader" model="Model.Result" />

<partial name="_RecipeList" model="Model.Result" />

<!-- Delete Cookbook Modal -->
<div class="modal fade" id="deleteCookbookModal" tabindex="-1" aria-labelledby="deleteCookbookModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteCookbookModalLabel">Delete Cookbook</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong>@Model.Result?.Name</strong>?</p>
                <p class="text-danger"><strong>This will permanently delete the cookbook and all @(Model.Result?.Recipes.Count ?? 0) recipe(s) inside it.</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form hx-post="?handler=Delete" hx-swap="none">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete Cookbook</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Share Modal (stub) -->
<div class="modal fade" id="shareModal" tabindex="-1" aria-labelledby="shareModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="shareModalLabel">Share Cookbook</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Share functionality coming soon!</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>


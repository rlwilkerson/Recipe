@model IReadOnlyList<Recipe.Web.Features.Cookbooks.GetCookbook.CookbookRecipeItem>

<div id="recipe-list-section">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Recipes</h2>
        <button hx-get="?handler=AddRecipeForm"
                hx-target="#recipe-list-section"
                hx-swap="outerHTML"
                class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add Recipe
        </button>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-text" style="font-size: 3rem; color: #6c757d;"></i>
            <p class="lead text-muted mt-3">No recipes in this cookbook yet.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var recipe in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@recipe.Title</h5>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <a href="/recipes/@recipe.PublicId/@recipe.Slug" class="btn btn-outline-primary btn-sm">
                                View Recipe
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@model Recipe.Web.Features.Cookbooks.GetCookbook.GetCookbookResponse

<div id="recipe-list-section">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Recipes</h2>
        @if (Model?.IsOwner == true)
        {
            <button hx-get="?handler=AddRecipeForm"
                    hx-target="#recipe-list-section"
                    hx-swap="outerHTML"
                    class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Add Recipe
            </button>
        }
    </div>

    @if (Model?.Recipes == null || !Model.Recipes.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-text" style="font-size: 3rem; color: #6c757d;"></i>
            <p class="lead text-muted mt-3">No recipes in this cookbook yet.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var recipe in Model.Recipes)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@recipe.Title</h5>

                            @if (!string.IsNullOrWhiteSpace(recipe.Description))
                            {
                                <p class="card-text text-muted small mb-3"
                                   style="overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                    @recipe.Description
                                </p>
                            }

                            @if (recipe.PrepTime.HasValue || recipe.CookTime.HasValue || recipe.Servings.HasValue)
                            {
                                <div class="d-flex gap-2 flex-wrap small text-muted mb-3">
                                    @if (recipe.PrepTime is > 0)
                                    {
                                        <span>🕐 @recipe.PrepTime min prep</span>
                                    }
                                    @if (recipe.CookTime is > 0)
                                    {
                                        <span>🍳 @recipe.CookTime min cook</span>
                                    }
                                    @if (recipe.Servings is > 0)
                                    {
                                        <span>🍽️ @recipe.Servings servings</span>
                                    }
                                </div>
                            }

                            <div class="mt-auto d-flex gap-2 flex-wrap">
                                <a href="/recipes/@recipe.PublicId/@recipe.Slug" class="btn btn-outline-primary btn-sm">
                                    View Recipe
                                </a>
                                @if (Model.IsOwner)
                                {
                                    <form hx-post="?handler=RemoveRecipe"
                                          hx-target="#recipe-list-section"
                                          hx-swap="outerHTML"
                                          hx-confirm="Remove '@recipe.Title' from this cookbook?">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="RecipeToRemovePublicId" value="@recipe.PublicId">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-x-lg"></i> Remove
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

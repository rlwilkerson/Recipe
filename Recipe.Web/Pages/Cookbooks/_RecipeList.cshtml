@model IReadOnlyList<Recipe.Web.Features.Cookbooks.GetCookbook.CookbookRecipeItem>

<div id="recipe-list-section">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Recipes</h2>
        <button hx-get="?handler=AddRecipeForm"
                hx-target="#recipe-list-section"
                hx-swap="outerHTML"
                class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add Recipe
        </button>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-text" style="font-size: 3rem; color: #6c757d;"></i>
            <p class="lead text-muted mt-3">No recipes in this cookbook yet.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var recipe in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@recipe.Title</h5>
                            
                            @* Description — will be visible when Fenster adds field to CookbookRecipeItem *@
                            @if (!string.IsNullOrWhiteSpace(recipe.Description))
                            {
                                <p class="card-text text-muted small mb-3" 
                                   style="overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                    @recipe.Description
                                </p>
                            }
                            
                            @* Timing & servings badges — will be visible when Fenster adds fields *@
                            @if (recipe.PrepTime.HasValue || recipe.CookTime.HasValue || recipe.Servings.HasValue)
                            {
                                <div class="d-flex gap-2 flex-wrap small text-muted mb-3">
                                    @if (recipe.PrepTime.HasValue && recipe.PrepTime.Value > 0)
                                    {
                                        <span>🕐 @recipe.PrepTime min prep</span>
                                    }
                                    @if (recipe.CookTime.HasValue && recipe.CookTime.Value > 0)
                                    {
                                        <span>🍳 @recipe.CookTime min cook</span>
                                    }
                                    @if (recipe.Servings.HasValue && recipe.Servings.Value > 0)
                                    {
                                        <span>🍽️ @recipe.Servings servings</span>
                                    }
                                </div>
                            }
                            
                            <div class="mt-auto">
                                <a href="/recipes/@recipe.PublicId/@recipe.Slug" class="btn btn-outline-primary btn-sm">
                                    View Recipe
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

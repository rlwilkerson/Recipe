<div class="modal show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Recipe to Cookbook</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" onclick="closeRecipeModal()"></button>
            </div>
            <form hx-post="?handler=AddRecipe"
                  hx-target="#cookbook-recipes"
                  hx-swap="outerHTML"
                  hx-on::after-request="if(event.detail.successful) closeRecipeModal()">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="recipeTitle" class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="recipeTitle" name="RecipeTitle" required maxlength="200">
                    </div>
                    <div class="mb-3">
                        <label for="recipeDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="recipeDescription" name="RecipeDescription" rows="2" maxlength="1000"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="closeRecipeModal()">Cancel</button>
                    <button type="submit" class="btn btn-success">Add Recipe</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function closeRecipeModal() {
        document.getElementById('recipe-modal-container').innerHTML = '';
    }
</script>

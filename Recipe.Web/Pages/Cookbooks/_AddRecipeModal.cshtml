<div class="modal show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Recipe to Cookbook</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" onclick="closeRecipeModal()"></button>
            </div>
            <form hx-post="?handler=AddRecipe"
                  hx-target="#cookbook-recipes"
                  hx-swap="outerHTML"
                  hx-on::after-request="if(event.detail.successful) closeRecipeModal()">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="recipeTitle" class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="recipeTitle" name="RecipeTitle" required maxlength="200">
                    </div>
                    <div class="mb-3">
                        <label for="recipeDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="recipeDescription" name="RecipeDescription" rows="2" maxlength="1000"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="recipeIngredients" class="form-label">Ingredients</label>
                        <textarea class="form-control" id="recipeIngredients" name="RecipeIngredients" rows="4"
                                  placeholder="One ingredient per line&#10;e.g. 2 cups flour&#10;1 tsp salt" maxlength="5000"></textarea>
                        <div class="form-text">Enter one ingredient per line</div>
                    </div>
                    <div class="mb-3">
                        <label for="recipeInstructions" class="form-label">Instructions</label>
                        <textarea class="form-control" id="recipeInstructions" name="RecipeInstructions" rows="5"
                                  placeholder="One step per line&#10;e.g. Preheat oven to 350°F&#10;Mix dry ingredients" maxlength="10000"></textarea>
                        <div class="form-text">Enter one step per line</div>
                    </div>
                    <div class="row">
                        <div class="col-4">
                            <label for="recipePrepTime" class="form-label">Prep Time (min)</label>
                            <input type="number" class="form-control" id="recipePrepTime" name="RecipePrepTime" min="0" max="9999">
                        </div>
                        <div class="col-4">
                            <label for="recipeCookTime" class="form-label">Cook Time (min)</label>
                            <input type="number" class="form-control" id="recipeCookTime" name="RecipeCookTime" min="0" max="9999">
                        </div>
                        <div class="col-4">
                            <label for="recipeServings" class="form-label">Servings</label>
                            <input type="number" class="form-control" id="recipeServings" name="RecipeServings" min="1" max="999">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="closeRecipeModal()">Cancel</button>
                    <button type="submit" class="btn btn-success">Add Recipe</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function closeRecipeModal() {
        document.getElementById('recipe-modal-container').innerHTML = '';
    }
</script>

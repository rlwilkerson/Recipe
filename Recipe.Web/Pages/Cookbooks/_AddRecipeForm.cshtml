<div id="recipe-list-section">
    <div class="card mb-4">
        <div class="card-header">
            <h2 class="mb-0">Add Recipe to Cookbook</h2>
        </div>
        <div class="card-body">
            <form hx-post="?handler=AddRecipe"
                  hx-target="#recipe-list-section"
                  hx-swap="outerHTML"
                  hx-include="closest form">
                @Html.AntiForgeryToken()
                
                <div class="mb-3">
                    <label for="recipeTitle" class="form-label">Title <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="recipeTitle" name="RecipeTitle"
                           required maxlength="200">
                </div>

                <div class="mb-3">
                    <label for="recipeDescription" class="form-label">Description</label>
                    <textarea class="form-control" id="recipeDescription" name="RecipeDescription"
                              rows="2" maxlength="1000"></textarea>
                </div>

                <div class="mb-3">
                    <label for="recipeIngredients" class="form-label">Ingredients</label>
                    <textarea class="form-control" id="recipeIngredients" name="RecipeIngredients"
                              rows="5" maxlength="5000"></textarea>
                    <div class="form-text">One ingredient per line</div>
                </div>

                <div class="mb-3">
                    <label for="recipeInstructions" class="form-label">Instructions</label>
                    <textarea class="form-control" id="recipeInstructions" name="RecipeInstructions"
                              rows="6" maxlength="10000"></textarea>
                    <div class="form-text">One step per line</div>
                </div>

                <div class="row mb-4">
                    <div class="col-4">
                        <label for="recipePrepTime" class="form-label">Prep Time (min)</label>
                        <input type="number" class="form-control" id="recipePrepTime" name="RecipePrepTime"
                               min="0" max="9999">
                    </div>
                    <div class="col-4">
                        <label for="recipeCookTime" class="form-label">Cook Time (min)</label>
                        <input type="number" class="form-control" id="recipeCookTime" name="RecipeCookTime"
                               min="0" max="9999">
                    </div>
                    <div class="col-4">
                        <label for="recipeServings" class="form-label">Servings</label>
                        <input type="number" class="form-control" id="recipeServings" name="RecipeServings"
                               min="1" max="999">
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Add Recipe
                    </button>
                    <button type="button" class="btn btn-secondary"
                            hx-get="?handler=RecipeList"
                            hx-target="#recipe-list-section"
                            hx-swap="outerHTML">
                        <i class="bi bi-x-lg"></i> Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
